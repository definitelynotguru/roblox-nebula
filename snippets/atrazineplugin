local AllNodes = {} --all known nodes

function NodeScan(p) --used to find all known nodes
	for _,v in pairs(p:GetChildren()) do
		if (v.Name == 'Node' or v:FindFirstAncestor("Nodes") ~= nil) and v:IsA("BasePart") then
			table.insert(AllNodes, v)
		end
		NodeScan(v)
	end
end

spawn(function()
	local AllNodes = {}
	NodeScan(workspace)	
end)

