function CreateTri()
	mouse.TargetFilter = TriPreviewObject
	local targ = mouse.Target
	if (TriPreviewObject and TriPreviewObject:FindFirstAncestor("Camera")) or targ ~= nil then
		local icheck = true
		local Margin = UsersettingsValue[21].Value
		for i, v in pairs(Points) do
			if v[1] == targ then
				if Indicator[1].Adornee == v[1] or Indicator[1].Adornee == v[2] then
					Indicator[1].Adornee = nil
				elseif Indicator[2].Adornee == v[1] or Indicator[2].Adornee == v[2] then
					Indicator[2].Adornee = nil
				end							
				if UnconfirmedNodes[1] and targ == UnconfirmedNodes[1] then
					UnconfirmedNodes[1]:Destroy()				
					table.remove(UnconfirmedNodes, 1)
				elseif UnconfirmedNodes[2] and targ == UnconfirmedNodes[2] then
					UnconfirmedNodes[2]:Destroy()				
					table.remove(UnconfirmedNodes, 2)
				end
				table.remove(Points, i)
				icheck = false 
				break 
			elseif Indicator[3].Adornee and (Indicator[3].Adornee.Position - v[2]).magnitude <= Margin then
				if UnconfirmedNodes[1] ~= nil and (Indicator[1].Adornee == UnconfirmedNodes[1] or Indicator[2].Adornee == UnconfirmedNodes[1]) and (Indicator[3].Adornee.Position == UnconfirmedNodes[1].Position) then
					if Indicator[1].Adornee == UnconfirmedNodes[1] then
						Indicator[1].Adornee = nil
					elseif Indicator[2].Adornee == UnconfirmedNodes[1] then
						Indicator[2].Adornee = nil
					end
					UnconfirmedNodes[1]:Destroy()
					table.remove(UnconfirmedNodes, 1)
				elseif UnconfirmedNodes[2] ~= nil and (Indicator[1].Adornee == UnconfirmedNodes[2] or Indicator[2].Adornee == UnconfirmedNodes[2]) and (Indicator[3].Adornee.Position == UnconfirmedNodes[2].Position) then
					if Indicator[1].Adornee == UnconfirmedNodes[2] then
						Indicator[1].Adornee = nil
					elseif Indicator[2].Adornee == UnconfirmedNodes[2] then
						Indicator[2].Adornee = nil
					end
					UnconfirmedNodes[2]:Destroy()
					table.remove(UnconfirmedNodes, 2)
				elseif Indicator[1] and (Indicator[1].Adornee == v[1] or (Indicator[1].Adornee.Position - v[2]).magnitude <= Margin) then
					Indicator[1].Adornee = nil
				elseif Indicator[2] and (Indicator[2].Adornee == v[1] or (Indicator[2].Adornee.Position - v[2]).magnitude <= Margin) then
					Indicator[2].Adornee = nil
				end
				table.remove(Points, i)			
				icheck = false 
				break 
			end
		end

		if TriangleSnapMode == 2 and (targ.Name ~= "Node" or targ:FindFirstAncestor("Nodes") == nil) then --Node only mode
			icheck = false
		end

		if icheck then
			local NewNode
			if TriangleSnapMode ~= 4 then
				local NoMatch = true
				for i, v in pairs(AllNodes) do
					if v then
						if (Indicator[3].Adornee and (Indicator[3].Adornee.Position - v.Position).magnitude <= Margin) or (TriPreviewObject and (TriPreviewObject.Position - v.Position).magnitude <= Margin) then
							NewNode = v
							NoMatch = false
							break
						end
					end		
				end
				if NoMatch == true then
					if (TriPreviewObject and PreviousNode and TriPreviewObject.Position == PreviousNode.Position) then
						NewNode = PreviousNode
					elseif targ ~= nil and targ.Name ~= "Node" and targ:FindFirstAncestor("Nodes") == nil then
						NewNode = MakeNode(NodeFolder, TriPreviewObject.Position, true)
					elseif targ ~= nil then
						NewNode = targ
					else
						NewNode = MakeNode(NodeFolder, TriPreviewObject.Position, true)
					end
				elseif NoMatch == false and NewNode == nil then
					NewNode = targ
				end
			else
				mouse.TargetFilter = TriPreviewObject
				NewNode = mouse.Target
			end
			table.insert(Points, {NewNode, NewNode.Position})
			if #Points >= 3 then
				local pts = {{Points[1][1], Points[1][2]}, {Points[2][1], Points[2][2]}, {Points[3][1], Points[3][2]}}
				local check = true
				for i, v in pairs(Triangles) do
					local check1 = pts[1][1] == v[2][1] or pts[1][1] == v[3][1] or pts[1][1] == v[4][1]
					local check2 = pts[2][1] == v[2][1] or pts[2][1] == v[3][1] or pts[2][1] == v[4][1]
					local check3 = pts[3][1] == v[2][1] or pts[3][1] == v[3][1] or pts[3][1] == v[4][1]
					if check1 and check2 and check3 then
						for _, a in pairs(v[1]) do
							a:Destroy()
						end
						for _, a in pairs(v[5]) do
							a:disconnect()
						end
						table.remove(Triangles, i)
						break
					end
				end		
				local align = TriangleDirectionMode	
				local n = 0
				
				if align == 3 then 
					n = -1 
				elseif align == 5 then 
					n = 0 
				elseif align == 4 then
					n = 1
				elseif align == 1 or align == 2 then
					local TestTriangle1, TestTriangle2 = drawTriangle(Points[1][2], Points[2][2], pts[3][2], -1) --Standard
					local TestTriangle3, TestTriangle4 = drawTriangle(Points[1][2], Points[2][2], pts[3][2], 1) --Inverted
					
					TestTriangle2:Destroy()
					TestTriangle4:Destroy()
					
					local TriMag1 = (TestTriangle1.Position - Vector3.new(TestTriangle1.Position.x, -10000, TestTriangle1.Position.z)).magnitude
					local TriMag2 = (TestTriangle3.Position - Vector3.new(TestTriangle3.Position.x, -10000, TestTriangle3.Position.z)).magnitude
					
					if TriMag1 <= TriMag2 then
						n = -1 --Standard
					else
						n = 1 --Inverted
					end
					TestTriangle1:Destroy()
					TestTriangle3:Destroy()
					if align == 2 then
						n = n*(-1)
					end
				end
				
				local Color = UsersettingsValue[4].Value
				local Material = UsersettingsValue[5].Value
				local Thickness = UsersettingsValue[13].Value
				local Transparency = UsersettingsValue[19].Value
				
				local nTriangles = {}
				nTriangles[1], nTriangles[2] = drawTriangle(Points[1][2], Points[2][2], pts[3][2], n, Color, Material, Thickness, Transparency)
				local nFunc = {}
				table.insert(Triangles, {nTriangles, pts[1], pts[2], pts[3], nFunc})
				for i = 1, 3 do
					table.insert(nFunc, Points[i][1].Changed:Connect(function(property)
						if property == "Position" then
							pts[i][2] = pts[i][1].Position
							for i, v in pairs(nTriangles) do
								v:Destroy()
							end
							nTriangles[1], nTriangles[2] = drawTriangle(pts[1][2], pts[2][2], pts[3][2], n, Color, Material, Thickness, Transparency)
						end
					end))
				end
				Points = {}
				UnconfirmedNodes = {}
				Indicator[1].Adornee = nil
				Indicator[2].Adornee = nil
				Indicator[3].Adornee = nil
				HistoryService:SetWaypoint("Action")			
			else
				Indicator[3].Adornee = nil
				if Indicator[1].Adornee == nil then
					Indicator[1].Color3 = BrickColor.new("Lime green").Color
					Indicator[1].SurfaceColor3 = BrickColor.new("Bright green").Color
					Indicator[1].Adornee = NewNode
					if TriangleSnapMode == 4 then
						Indicator[1].Adornee = targ
					end
				else
					Indicator[2].Color3 = BrickColor.new("Lime green").Color
					Indicator[2].SurfaceColor3 = BrickColor.new("Bright green").Color
					Indicator[2].Adornee = NewNode	
					if TriangleSnapMode == 4 then
						Indicator[2].Adornee = targ
					end
				end
			end
		end
	end	
end

function CreateMove() --highlights nodes/target when you hover over them
	if WhatMenuOpen == "Terrain" then
		if workspace.Camera:FindFirstChild("TriPreview") ~= nil then
			mouse.TargetFilter = workspace.Camera.TriPreview
		end
		local targ = mouse.Target
		local icheck = true
		for i,v in pairs(Points) do if v[1] == targ then icheck = false	break end end
		if targ ~= nil then 
			if icheck then
				if (targ.Name == "Node" or targ:FindFirstAncestor("Nodes")) and targ:IsA("BasePart") then
					RemoveTriPreview()
					Indicator[3].Color3 = BrickColor.new("Lime green").Color
					Indicator[3].SurfaceColor3 = BrickColor.new("Bright green").Color
					Indicator[3].Adornee = targ
					PreviousNode = targ
				elseif TriPreviewObject and PreviousNode and TriPreviewObject.Position == PreviousNode.Position then
					local Mag = (mouse.Hit.p - PreviousNode.Position).magnitude
					if Mag <= UsersettingsValue[20].Value then
						RemoveTriPreview()
						Indicator[3].Color3 = BrickColor.new("Lime green").Color
						Indicator[3].SurfaceColor3 = BrickColor.new("Bright green").Color
						Indicator[3].Adornee = PreviousNode
					else
						TriPreview(targ)						
					end
				else					
					TriPreview(targ)
				end
			else
				RemoveTriPreview()
			end
		else
			mouse.TargetFilter = nil
			local targ2 = mouse.target
			if targ2 == nil then 
				RemoveTriPreview()
			end
		end
	end
end

RemovedTriangles = {}

function RemoveTri(MOUSETARGET)
	local targ = MOUSETARGET
	if targ~=nil then
		for i,v in pairs(Triangles) do
			if targ==v[1][1] or targ==v[1][2] then
				for _,a in pairs(v[1]) do
					a:remove()
				end
				for _,a in pairs(v[5]) do
					a:disconnect()
				end
				table.insert(RemovedTriangles,i)
				Indicator[1].Adornee=nil
				Indicator[2].Adornee=nil
				HistoryService:SetWaypoint("Action")
				break
			end
		end
	end
end

function TriMove() --highlights triangles to remove when hovering over them
	local targ=mouse.Target
	if targ~=nil then
		local tr
		for i,v in pairs(Triangles) do
			if targ==v[1][1] or targ==v[1][2] then tr={v[1][1],v[1][2]} break end
		end
		if tr~=nil then
			Indicator[1].Color3=BrickColor.new("Really red").Color
			Indicator[1].SurfaceColor3=BrickColor.new("Bright red").Color
			Indicator[2].Color3=BrickColor.new("Really red").Color
			Indicator[2].SurfaceColor3=BrickColor.new("Bright red").Color
			Indicator[1].Adornee=tr[1]
			Indicator[2].Adornee=tr[2]
		else
			Indicator[1].Adornee=nil
			Indicator[2].Adornee=nil	
		end
	else
		Indicator[1].Adornee=nil
		Indicator[2].Adornee=nil	
	end
end

