function FindGuiToClose(v)
	local x = v.Parent:GetChildren()
	for i, c in pairs(x) do
		if c:IsA("Frame") or c:IsA("ScrollingFrame") then
			return(c)
		end
	end
end

for i, v in pairs(SubMenuHeaders) do
	local MenuToClose = FindGuiToClose(v)
	v.MouseEnter:Connect(function()
		MenuToClose.Visible = true
		v:TweenPosition(UDim2.new(0,0,0.312,0),"Out", "Sine", 0.2, true)
		MenuToClose:TweenSizeAndPosition(UDim2.new(1,0,0.6,0), UDim2.new(0,0,0.4,0), "Out", "Sine", 0.2, true)
		wait(0.2)
		MenuToClose.Visible = true
	end)
	v.Parent.MouseLeaveBox.MouseLeave:Connect(function()
		MenuToClose:TweenSizeAndPosition(UDim2.new(1,0,0,0), UDim2.new(0,0,1,0), "In", "Sine", 0.2, true)
		v:TweenPosition(UDim2.new(0,0,0.92, 0),"In", "Sine", 0.2, true)
		wait(0.2)
		MenuToClose.Visible = false
	end)
end

---------------------------------------------------------------------------------------------- Close/Open Modules ----------------------------------------------------------------------------------------------
local Modules = {"Terrain", "Trees", "Rocks", "Settings"}

function OpenModule(module)
	if WhatMenuOpen ~= nil then
		for i, v in pairs(Modules) do
			if Main:FindFirstChild(v .. "Menu") then
				TweenGui(Main[v .. "Menu"], 0.225, 1)
				Menu[v .. "Frame"].Color:TweenSizeAndPosition(UDim2.new(0,0,0.15,0), UDim2.new(0.5,0,1,0), "Out", "Quart", 0.3, true)
			end
		end
	end
	
	WhatMenuOpen = module
	
	CloseTools()
	CloseGrid()
	Menu[module .. "Frame"].BackgroundTransparency = 1
	TweenGui(Main[module .. "Menu"], 0.225, 0.52)
	TweenGui(Menu, 0.225, 0.93)
	wait(0.3)
	if WhatMenuOpen == module then
		Menu[module .. "Frame"].Color:TweenSizeAndPosition(UDim2.new(1,0,0.15,0), UDim2.new(0,0,1,0), "Out", "Quart", 0.35, true)
	end
end

function CloseModule(module)	
	WhatMenuOpen = nil	
	CloseTools()
	CloseGrid()
	Menu[module .. "Frame"].BackgroundTransparency = 1
	TweenGui(Main[module .. "Menu"], 0.225, 1)
	TweenGui(Menu, 0.225, 0.87)
	wait(0.3)
	if WhatMenuOpen ~= module then
		Menu[module .. "Frame"].Color:TweenSizeAndPosition(UDim2.new(0,0,0.15,0), UDim2.new(0.5,0,1,0), "Out", "Quart", 0.35, true)
	end
end

----------------------------------------------- Opens module pressed
for i, v in pairs(Modules) do
	Menu[v].MouseButton1Click:Connect(function()
		if Main:FindFirstChild(v .. "Menu") then
			if WhatMenuOpen == v then	
				CloseModule(v)
			else		
				OpenModule(v)
			end
		end
	end)
end

