	local o = {
		CFrame.new(sx,sy,sz); --corners
		CFrame.new(-sx,sy,sz);
		CFrame.new(sx,-sy,sz);
		CFrame.new(sx,sy,-sz);
		CFrame.new(-sx,-sy,sz);
		CFrame.new(sx,-sy,-sz);
		CFrame.new(-sx,-sy,-sz);
		CFrame.new(-sx,sy,-sz);
		
		CFrame.new(0,sy,0); 
		CFrame.new(sx,sy,0);
		CFrame.new(0,sy,sz);
		CFrame.new(-sx,sy,0);
		CFrame.new(0,sy,-sz);		
		CFrame.new(sx,0,0);
		CFrame.new(0,0,sz);
		CFrame.new(-sx,0,0);
		CFrame.new(0,0,-sz);		
		CFrame.new(sx,0,sz);
		CFrame.new(sx,0,-sz);
		CFrame.new(-sx,0,sz);
		CFrame.new(-sx,0,-sz);
		CFrame.new(0,-sy,0);
		CFrame.new(sx,-sy,0);
		CFrame.new(0,-sy,sz);
		CFrame.new(-sx,-sy,0);
		CFrame.new(0,-sy,-sz);			
	}
	local close
	local cmag = 100000
	local prevNode = nil
	if IsPreviousNode == true then
		prevNode = PreviousNode
	end
	for i, cf in pairs(o) do
		local pos = part.CFrame*cf
		local mag = (hit.p - pos.p).magnitude
		if prevNode ~= nil then
			local posprevNode = prevNode.CFrame	
			local magprevNode = (hit.p - posprevNode.p).magnitude
			if magprevNode < UsersettingsValue[7].Value*2 then
				close = posprevNode
				cmag = magprevNode
			elseif mag < cmag then
				close = pos
				cmag = mag
			end
		elseif mag < cmag then
			close = pos
			cmag = mag
		end
	end
	if UsersettingsValue[22].Value == false and part:FindFirstAncestor("TriangleTerrain") then
		cmag = 100000
	end	
	return close.p, cmag
end

