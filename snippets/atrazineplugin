function MakeNodeFolder()
	NodeFolder = workspace:FindFirstChild("Nodes")
	if NodeFolder == nil or NodeFolder.ClassName ~= "Folder" then
		NodeFolder = Instance.new("Folder", workspace)
		NodeFolder.Name = "Nodes"
	end
end

function RemoveEmptyFolders()
	wait()
	if NodeFolder ~= nil then	
		local c = NodeFolder:GetChildren()
		if c[1] == nil then
			NodeFolder:remove()
		end
	end
end

