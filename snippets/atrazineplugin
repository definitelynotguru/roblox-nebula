local UnconfirmedNodes = {}

function MakeNode(Folder, OptionalPosition, GiveNode)
	if NodePreviewPosition ~= nil or OptionalPosition ~= nil then
		local inputword = tostring(BrickColor.new(UsersettingsValue[10].Value))
		local pattern = "[^%s,]+"
		local NodeSubFolderName = ""
		local match = ""
		for match in inputword:gmatch(pattern) do
   			NodeSubFolderName = tostring(NodeSubFolderName) .. match
		end
		
		if Folder == nil then
			MakeNodeFolder()
			Folder = workspace.Nodes
		end
		
		local NodeSubFolder = Folder:FindFirstChild(NodeSubFolderName .. "Nodes")
		if NodeSubFolder == nil then
			NodeSubFolder = Instance.new("Folder", Folder)
			NodeSubFolder.Name = (NodeSubFolderName .. "Nodes")
		end
		
		local Node = DefaultNode:Clone()
		Node.Parent = NodeSubFolder
		Node.Transparency = UsersettingsValue[9].Value
		Node.BrickColor = BrickColor.new(UsersettingsValue[10].Value)
		Node.Material = NodeMaterial	
		if OptionalPosition ~= nil then
			Node.Position = OptionalPosition
		else
			Node.Position = NodePreviewPosition
		end
		Node.Size = Vector3.new(UsersettingsValue[7].Value, UsersettingsValue[7].Value, UsersettingsValue[7].Value)
		if GiveNode == nil then
			table.insert(AllNodes, Node)
		end
		
		HistoryService:SetWaypoint("Action")
		if GiveNode and GiveNode == true then
			table.insert(UnconfirmedNodes, Node)
			return Node
		end
	else
		print("invalid location")
	end
end

