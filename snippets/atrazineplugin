function CloseTools()
	if PluginOn == false then
		plugin:Activate(true)
		button:SetActive(true)
		PluginOn = true
	end
	
	for i, v in pairs(ToolListeners) do
		v:disconnect()
	end
	
	for i, v in pairs(Indicator) do
		v.Adornee = nil
	end
	
	for i, v in pairs(UnconfirmedNodes) do
		v:Destroy()
	end
	
	UnconfirmedNodes = {}
	RemovedTriangles = {}
	
	local NodeFolderExists = workspace:FindFirstChild("Nodes")
	if NodeFolderExists and NodeFolderExists:IsA("Folder") then
		if NodeFolderExists:FindFirstChild("PreviewNode") then
			workspace.Nodes.PreviewNode:remove()
		end
	end
	
	RemoveTriPreview()
	
	for i, v in pairs(ToolButtons) do
		v.SelectedIndicator.Visible = false
		v.BackgroundTransparency = 1
	end

	UsersettingsValue[14].Value = false
	UsersettingsValue[15].Value = false
	UsersettingsValue[16].Value = false
	UsersettingsValue[17].Value = false
	UsersettingsValue[18].Value = false
	
	Points = {}
		
	mouse.TargetFilter = nil
	
	spawn(function()
		AllNodes = {}
		NodeScan(workspace)
	end)	
end

